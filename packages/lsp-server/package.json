{
    "name": "@algolang/lsp-server",
    "version": "1.0.0",
    "description": "LSP Server for AlgoLang",
    "type": "module",
    "main": "./dist/server.js",
    "bin": {
        "algolang-lsp": "./bin/algolang-lsp"
    },
    "files": [
        "dist",
        "bin"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "keywords": [
        "algolang",
        "lsp",
        "language-server",
        "algorithmique",
        "education"
    ],
    "author": "AlgoLang Team",
    "license": "MIT",
    "scripts": {
        "build": "bun build src/server.ts --outdir dist --target node",
        "prepublishOnly": "bun run build",
        "watch": "bun build src/server.ts --outdir dist --target node --watch"
    },
    "dependencies": {
        "vscode-languageserver": "^9.0.1",
        "vscode-languageserver-textdocument": "^1.0.11",
        "@algolang/compiler": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "typescript": "^5.3.3"
    }
}
