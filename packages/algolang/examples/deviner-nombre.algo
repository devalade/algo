PROGRAMME DevinerNombre;
VAR
  secret: ENTIER;
  essai: ENTIER;
  compteur: ENTIER;
  trouve: BOOLEEN;
DEBUT
  secret := 42;
  compteur := 0;
  trouve := FAUX;
  
  ECRIRE("Jeu du nombre secret !");
  ECRIRE("Devinez un nombre entre 1 et 100");
  
  TANTQUE NON trouve FAIRE
    ECRIRE("Votre essai : ");
    LIRE(essai);
    compteur := compteur + 1;
    
    SI essai = secret ALORS
      trouve := VRAI;
    FINSI
  FINTANTQUE
  
  ECRIRE("Bravo ! Trouvé en ", compteur, " essais !");
FIN
