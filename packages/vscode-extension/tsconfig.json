{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ESSource",
        "lib": [
            "ESNext"
        ],
        "strict": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}