{
    "scopeName": "source.algo",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.algo",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.algo",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.algo",
                    "match": "\\b(programme|debut|fin|var|si|alors|sinon|finsi|tantque|faire|pour|allant|de|à|repeter|jusqu'à|finpour|fintantque)\\b"
                },
                {
                    "name": "storage.type.algo",
                    "match": "\\b(entier|reel|booleen|chaine)\\b"
                },
                {
                    "name": "constant.language.boolean.algo",
                    "match": "\\b(vrai|faux)\\b"
                },
                {
                    "name": "support.function.algo",
                    "match": "\\b(lire|ecrire)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.algo",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.algo",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.algo",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.algo",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.algo",
                    "match": "(<>|<=|>=|=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.algo",
                    "match": "(\\+|\\-|\\*|/)"
                },
                {
                    "name": "keyword.operator.logical.algo",
                    "match": "\\b(et|ou|non)\\b"
                }
            ]
        }
    }
}