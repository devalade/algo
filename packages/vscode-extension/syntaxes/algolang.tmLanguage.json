{
    "scopeName": "source.algo",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.algo",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.algo",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.algo",
                    "match": "(?i)\\b(PROGRAMME|DEBUT|FIN|VAR|SI|ALORS|SINON|FINSI|TANTQUE|FAIRE|POUR|ALLANT|DE|REPETER|FINPOUR|FINTANTQUE|TABLEAU|FONCTION|PROCEDURE|RETOURNER)\\b|(?i)\\bJUSQU'A\\b"
                },
                {
                    "name": "storage.type.algo",
                    "match": "(?i)\\b(ENTIER|REEL|BOOLEEN|CHAINE)\\b"
                },
                {
                    "name": "constant.language.boolean.algo",
                    "match": "(?i)\\b(VRAI|FAUX)\\b"
                },
                {
                    "name": "keyword.operator.logical.algo",
                    "match": "(?i)\\b(ET|OU|NON)\\b"
                },
                {
                    "name": "support.function.algo",
                    "match": "(?i)\\b(LIRE|ECRIRE|abs|max|min|mod|racine_carree|taille|sous_chaine|concat|entier_en_reel|reel_en_entier)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.algo",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.algo",
                    "match": "\\\\."
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.algo",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.algo",
                    "match": ":="
                },
                {
                    "name": "keyword.operator.comparison.algo",
                    "match": "(<>|<=|>=|=|<|>)"
                },
                {
                    "name": "keyword.operator.arithmetic.algo",
                    "match": "(\\+|\\-|\\*|/)"
                }
            ]
        }
    }
}