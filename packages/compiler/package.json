{
  "name": "@devalade/algolang",
  "version": "1.0.0",
  "description": "Compilateur AlgoLang — langage de programmation éducatif pour l'algorithmique",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "algolang": "./bin/algolang"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "algorithmique",
    "algorithme",
    "education",
    "compiler",
    "algolang",
    "french",
    "programmation"
  ],
  "author": "AlgoLang Team",
  "license": "MIT",
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --outfile=cli.js --target=node && bun build src/index.ts --outdir dist --outfile=index.js --target=node",
    "prepublishOnly": "bun run build",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check src/",
    "format": "bunx @biomejs/biome format --write src/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@types/bun": "latest",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2"
  }
}
