PROGRAMME TestLSP;

VAR
  age, score : ENTIER;
  nom : CHAINE;
  estActif : BOOLEEN;

DEBUT
  // Test : survoler 'ECRIRE' ou 'score'
  ECRIRE("Bienvenue dans le test d'AlgoLang LSP");

  score := 10 + 5;

  // Test : FAIRE une erreur de syntaxe (enlever le FINSI par exemple)
  SI score > 10 ALORS
    ECRIRE("Bravo !");
  FINSI;

  // Test : Auto-complétion (taper 'TAN' ou 'POU')
  TANTQUE score < 20 FAIRE
    score := score + 1;
  FINTANTQUE;

  ECRIRE("FIN du test. Valeur finale du score : ", score);
FIN


